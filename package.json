{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "NODE_ENV=production next build",
    "analyze": "next build",
    "start": "NODE_ENV=production next start",
    "mongo:local": "docker run -d --name tpk-mongo -p 27017:27017 mongo:7",
    "seed:admin": "node scripts/seed-admin-user.mjs",
    "seed:demo": "node scripts/seed-demo-data.mjs",
    "test:smoke": "node scripts/smoke-check.mjs",
    "setup:local": "npm run seed:admin && npm run seed:demo && npm run test:smoke",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true});console.log('Cleaned .next');}catch(e){if(e.code!=='ENOENT')throw e;console.log('No .next folder');}\"",
    "lint": "eslint",
    "import:neet-biology": "node scripts/import-neet-biology-data.mjs",
    "import:neet-counseling": "node scripts/import-neet-counseling-pdf.mjs",
    "import:neet-counseling:r2": "node scripts/import-neet-counseling-pdf.mjs --round=2",
    "import:neet-counseling:r3": "node scripts/import-neet-counseling-pdf.mjs --round=3",
    "normalize:media-folders": "node scripts/normalize-media-folders.mjs"
  },
  "dependencies": {
