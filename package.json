    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.24",
    "jsonwebtoken": "^9.0.2",
    "lexical": "^0.38.1",
    "lucide-react": "^0.561.0",
    "marked": "^17.0.1",
    "mathjax": "^2.7.9",
    "md-to-pdf": "^5.2.5",
    "mongoose": "^8.19.2",
    "next": "16.0.1",
    "nodemailer": "^7.0.13",
    "pdf-parse": "^2.4.5",
    "qs": "^6.14.0",
    "react": "19.2.0",
